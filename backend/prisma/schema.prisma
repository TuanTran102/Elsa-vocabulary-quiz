generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum GameRoomStatus {
  WAITING
  IN_PROGRESS
  COMPLETED
}

model Quiz {
  id        String      @id @default(uuid())
  title     String
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")
  questions Question[]
  gameRooms GameRoom[]

  @@map("quizzes")
}

model Question {
  id               String   @id @default(uuid())
  quizId           String   @map("quiz_id")
  content          String
  options          Json     // Array of strings
  correctAnswer    String   @map("correct_answer")
  points           Int      @default(1000)
  timeLimitSeconds Int      @default(30) @map("time_limit_seconds")
  quiz             Quiz     @relation(fields: [quizId], references: [id])
  answers          Answer[]

  @@map("questions")
}

model GameRoom {
  id          String         @id @default(uuid())
  pin         String         @unique
  quizId      String         @map("quiz_id")
  status      GameRoomStatus @default(WAITING)
  startedAt   DateTime?      @map("started_at")
  completedAt DateTime?      @map("completed_at")
  createdAt   DateTime       @default(now()) @map("created_at")
  quiz        Quiz           @relation(fields: [quizId], references: [id])
  results     PlayerResult[]

  @@map("game_rooms")
}

model PlayerResult {
  id          String    @id @default(uuid())
  gameRoomId  String    @map("game_room_id")
  nickname    String
  finalScore  Int       @default(0) @map("final_score")
  rank        Int?
  completedAt DateTime  @map("completed_at")
  gameRoom    GameRoom  @relation(fields: [gameRoomId], references: [id])
  answers     Answer[]

  @@map("player_results")
}

model Answer {
  id              String       @id @default(uuid())
  playerResultId  String       @map("player_result_id")
  questionId      String       @map("question_id")
  userAnswer      String       @map("user_answer")
  isCorrect       Boolean      @map("is_correct")
  pointsAwarded   Int          @map("points_awarded")
  submittedAt     DateTime     @default(now()) @map("submitted_at")
  playerResult    PlayerResult @relation(fields: [playerResultId], references: [id])
  question        Question     @relation(fields: [questionId], references: [id])

  @@map("answers")
}
